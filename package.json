{
  "name": "opencode-path",
  "version": "0.3.1",
  "description": "Structured multi-agent workflow CLI for opencode",
  "type": "module",
  "bin": {
    "opencode-path": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "workflow",
    "cli",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
